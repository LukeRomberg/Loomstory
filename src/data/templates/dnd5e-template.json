  {
    "key": "combat",
    "label": "Combat",
    "icon": "swords",
    "order": 3,
    "layout": "grid",
    "columns": 4,
    "fields": [
      {
        "key": "ac",
        "label": "Armor Class",
        "type": "number",
        "order": 1,
        "storage": { "target": "data", "path": "ac" },
        "min": 0
      },
      {
        "key": "initiative",
        "label": "Initiative",
        "type": "number",
        "order": 2,
        "storage": { "target": "data", "path": "initiative" },
        "computed": {
          "formula": "floor((dex - 10) / 2)",
          "depends_on": ["dex"],
          "display_prefix": "+"
        }
      },
      {
        "key": "speed",
        "label": "Speed",
        "type": "number",
        "order": 3,
        "storage": { "target": "data", "path": "speed" },
        "default_value": 30,
        "help_text": "Walking speed in feet"
      },
      {
        "key": "inspiration",
        "label": "Inspiration",
        "type": "boolean",
        "order": 4,
        "storage": { "target": "data", "path": "inspiration" },
        "default_value": false
      },
      {
        "key": "proficiency_bonus",
        "label": "Proficiency Bonus",
        "type": "number",
        "order": 5,
        "storage": { "target": "data", "path": "proficiency_bonus" },
        "computed": {
          "formula": "floor((level - 1) / 4) + 2",
          "depends_on": ["level"],
          "display_prefix": "+"
        }
      },
      {
        "key": "hp_current",
        "label": "Current HP",
        "type": "number",
        "order": 6,
        "storage": { "target": "core", "column": "hp_current" },
        "min": 0
      },
      {
        "key": "hp_max",
        "label": "Max HP",
        "type": "number",
        "order": 7,
        "storage": { "target": "core", "column": "hp_max" },
        "min": 0
      },
      {
        "key": "hp_temp",
        "label": "Temp HP",
        "type": "number",
        "order": 8,
        "storage": { "target": "data", "path": "hp_temp" },
        "default_value": 0,
        "min": 0
      },
      {
        "key": "hit_dice",
        "label": "Hit Dice",
        "type": "resource_bar",
        "order": 9,
        "storage": { "target": "resource", "resource_key": "hit_dice" }
      },
      {
        "key": "death_saves_success",
