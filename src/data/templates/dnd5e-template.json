          {
            "key": "str_mod",
            "label": "Modifier",
            "type": "number",
            "order": 1,
            "storage": { "target": "stat", "stat_key": "str", "data_fields": ["modifier"] },
            "computed": {
              "formula": "floor((str - 10) / 2)",
